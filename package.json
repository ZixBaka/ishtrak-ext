{
  "name": "ishtrak-ext",
  "version": "0.1.0",
  "description": "Ishtrak browser extension — git-native task automation for any project management platform",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
